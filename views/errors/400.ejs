<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <link rel="stylesheet" href="/css/400.css">
        <title>400 • Bad Request</title>
    </head>
    <body>
        <main class="card" role="main" aria-labelledby="title">
            <div class="row">
            <div class="icon" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                <line x1="12" y1="9" x2="12" y2="13"/>
                <circle cx="12" cy="17" r="1"/>
                </svg>
            </div>
            <div class="errorcode_container">
                <div class="errorcode">
                <div class="code">400</div>
                <h1 id="title">Bad request</h1>
                </div>
                <p>We couldn't understand that request. Maybe an invalid parameter or malformed payload.</p>
                <div class="actions">
                <a class="button" href="/">Go home</a>
                <a class="ghost" href="javascript:location.reload()">Try again</a>
                </div>
                <small>If you think this is a server error, contact support with the request details.</small>
            </div>
            </div>
        </main>
    </body>
</html>

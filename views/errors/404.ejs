<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <link rel="stylesheet" href="/css/404.css">
        <title>404 • Not Found</title>
    </head>
    <body>
        <main class="card" role="main" aria-labelledby="title">
            <div class="row">
            <div class="icon" aria-hidden="true">
                <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#0b907f" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 12-9 12S3 17 3 10A9 9 0 0 1 21 10z"/>
                <circle cx="12" cy="10" r="2.5"/>
                </svg>
            </div>
            <div class="errorcode_container">
                <div class="errorcode"style="">
                <div class="code">404</div>
                <h1 id="title">Page not found</h1>
                </div>
                <p>We couldn't find what you're looking for. The link may be outdated or mistyped.</p>
                <div class="actions">
                <a class="button" href="/">Back to home</a>
                </div>
            </div>
            </div>
        </main>
    </body>
</html>

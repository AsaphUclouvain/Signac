<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link rel="stylesheet" href="/css/500.css">
		<title>500 • Server error</title>
	</head>
	<body>
		<main class="card" role="main" aria-labelledby="title">
			<div class="row">
			<div class="icon" aria-hidden="true">
				<svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#ff9bb3" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
				<rect x="3" y="7" width="18" height="11" rx="2"/>
				<path d="M9 3v4M15 3v4"/>
				<circle cx="9.5" cy="12" r="1"/>
				<circle cx="14.5" cy="12" r="1"/>
				<path d="M9 17c1.5-1 4.5-1 6 0"/>
				</svg>
			</div>
			<div class="errorcode_container">
				<div class="errorcode">
				<div class="code">500</div>
				<h1 id="title">Server error</h1>
				</div>
				<p>Something went wrong on our side. The engineers have been notified.</p>
				<div class="actions">
				<a class="button" href="/">Try homepage</a>
				</div>
				<small>If the problem persists, please copy this URL and contact support.</small>
			</div>
			</div>
		</main>
	</body>
</html>

<%- include('./templates/head', {title : 'login'}) %>  
    <body class="background-blue-3">
        <%- include('./templates/simple_header') %>
        <main>
            <div class="login-box">
                <form action="/api/auth/login"
                      method="POST"
                      enctype="application/x-www-form-urlencoded"
                      id="login-form">
                    <h2>Login</h2>
                    <div class="error-message">
                        <p><%= errorMsg %></p>
                    </div>
                    <div class="input-box">
                        <span class="icon"><i class="fa-solid fa-user"></i></span>
                        <input type="text" name="ename" value="<%= ename %>" required>
                        <label for="ename">Email or Username</label>
                    </div>
                    <div class="input-box">
                        <span class="icon"><i class="fa-solid fa-lock"></i></span>
                        <input type="password" name="password" value="" required>
                        <label for="password">Password</label>
                    </div>
                    <div class="remember-forgot">
                        <label><input type="checkbox" name="remember">Remember me</label>
                    </div>
                    <button class="button-auth" type="submit">Login</button>
                    <div class="register-link">
                        <p>Don't have an account ? <a href="/api/auth/register">Register</a></p>
                    </div>
                </form>
            </div>
        </main>
        <%- include('./templates/footer') %>
    </body>
</html>
<%- include('./templates/head', {title  : 'report'}) %>
    <body class="background-blue-3">
        <%- include('./templates/header', {fullname : user.fullname, avatar}) %>
        <main>
            <div class="report-box">
                <form method="POST"
                    enctype="application/x-www-form-urlencoded"
                    action="/api/incident/report"
                    id="report-form">
                    <h2>Report Form</h2>
                    <div class="error-message">
                        <p><%= errorMsg %></p>
                    </div>
                    <div class="address-box">
                        <div class="input-box">
                            <input type="text" name="street" value="<%= street %>" minlength="2" maxlength="50" required>
                            <label for="street">Street</label>
                        </div>
                    </div>
                    <div class="address-box">
                        <div class="input-box">
                            <input type="text" name="city" value="<%= city %>" minlength="2" maxlength="50" required>
                            <label for="city">City</label>
                        </div>
                        <div class="input-box">
                            <input type="number" min="1000" max="9992" step="1" name ="postcode" value="<%= postcode %>" required>
                            <label for="post-code">Postal Code</label>
                        </div>
                    </div>
                    <div class="description">
                        <label for="description">Description</label>
                        <textarea name="description" value="<%= description %>" minlength="30" maxlength="300" required></textarea>
                    </div>
                    <div class="action">
                        <button class="button-auth" type="submit">Report</button>
                        <button class="button-auth"><a href="/api/incident/list">Cancel</a></button>
                    </div>
                </form>
            </div>
        </main>
        <%- include('./templates/footer') %>
    </body>
</html>
